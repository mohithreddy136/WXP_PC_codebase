<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Score Production suite" configfailurepolicy="continue">


	<listeners>
		<listener class-name="com.basesource.utils.ExtentReport" />
		<listener class-name="com.basesource.utils.RetryListener" />
	</listeners>

	<test verbose="2" name="DEX tests" enabled="true">
		<groups>
			<run>
				<include name="PRODUCTION_SCORE" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.DEXTest" />
		</classes>
	</test>

	<test verbose="2" name="Applications tests" enabled="true">
		<groups>
			<run>
				<include name="PRODUCTION_SCORE" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.DEXTest" />
		</classes>
	</test>
</suite>