<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Scripts Production Suite" >

    <listeners>
        <listener class-name="com.basesource.utils.ExtentReport" />
        <listener class-name="com.basesource.utils.RetryListener" />
    </listeners>


    <test verbose="2" name="Scripts tests" enabled="true">
        <groups>
            <run>
                <include name="PRODUCTION_CONFIGSCRIPTS" />
            </run>
        </groups>

        <classes>
            <class name="com.testscripts.daasui.WEPScriptsTest" />
        </classes>
    </test>
</suite>