<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="CDC Production suite"
	configfailurepolicy="continue">


	<listeners>
		<listener class-name="com.basesource.utils.ExtentReport" />
		<listener class-name="com.basesource.utils.RetryListener" />
	</listeners>

	<test verbose="2" name="WEP CDC tests" enabled="true">
		<groups>
			<run>
				<include name="PRODUCTION_PULSES_CDC" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.WEPCDCTest" />
		</classes>
	</test>

</suite>