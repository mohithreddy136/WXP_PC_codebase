<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="REPORTS REGRESSION suite" configfailurepolicy="continue">
	<listeners>
		<listener class-name="com.basesource.utils.ExtentReport" />
		<listener class-name="com.basesource.utils.RetryListener" />
	</listeners>
	<test verbose="2" name="WEPIntegrations-Sustaiability" enabled="true">
		<groups>
			<run>
				<include name="REGRESSION_INTEGRATIONS" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.WEPSustainabilityTest" />
		</classes>
	</test>
	<!-- Remediation Test  -->
	<test verbose="2" name="WEPIntegrations-Remediation" enabled="true">
		<groups>
			<run>
				<include name="REGRESSION_INTEGRATIONS" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.WEPRemediationTest" />
		</classes>
	</test>
</suite>
