            <class name="com.testscripts.daasui.WEPCustomerHomeTest"/>
            <class name="com.testscripts.daasui.WEPGroupsTest"/>
            <class name="com.testscripts.daasui.WEPPolicyPageTest"/> 
            <class name="com.testscripts.daasui.LogTest"/>
            <class name="com.testscripts.daasui.SettingsTest"/>            
            <class name="com.testscripts.daasui.WEPVyoptaIntegrationTest"/>
            <class name="com.testscripts.daasui.WEPAlertsDashboardPageTest"/>  
