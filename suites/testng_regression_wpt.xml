<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="WPT REGRESSION SUITE" configfailurepolicy="continue">
	<listeners>
		<listener class-name="com.basesource.utils.ExtentReport" />
		<listener class-name="com.basesource.utils.RetryListener" />
	</listeners>

    <!-- WEPWPT Test -->
	<test verbose="2" name="WEPWPTTest" enabled="true">
		<groups>
			<run>
				<include name="REGRESSION_WPT" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.WEPWPTTest" />
		</classes>
	</test>
</suite>
