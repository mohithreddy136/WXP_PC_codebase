<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Score Production suite"
	configfailurepolicy="continue">


	<listeners>
		<listener class-name="com.basesource.utils.ExtentReport" />
		<listener class-name="com.basesource.utils.RetryListener" />
	</listeners>

	<test verbose="2" name="WEP Sustainability tests" enabled="true">
		<groups>
			<run>
				<include name="PRODUCTION_PULSES_EE_SUSTAIN" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.WEPSustainabilityTest" />
		</classes>
	</test>

	<test verbose="2" name="Script - Remediations tests" enabled="true">
		<groups>
			<run>
				<include name="PRODUCTION_PULSES_EE_SUSTAIN" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.WEPRemediationTest" />
		</classes>
	</test>

	<test verbose="2" name="PULSES tests" enabled="true">
		<groups>
			<run>
				<include name="PRODUCTION_PULSES_EE_SUSTAIN" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.WEPPulsesTest" />
		</classes>
	</test>

	<test verbose="2" name="EE Score tests" enabled="false">
		<groups>
			<run>
				<include name="PRODUCTION_PULSES_EE_SUSTAIN" />
			</run>
		</groups>
		<classes>
			<class name="com.testscripts.daasui.WEXEEScoreTest" />
		</classes>
	</test>
</suite>